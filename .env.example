# GEMS_OCR 환경 변수 (PROJECT/GEMS_PROJECT_GUIDE.md §4 참고)
# 사용법: 이 파일을 복사하여 .env 로 저장한 뒤 실제 값으로 채우세요.

# Database (반드시 사용자 DB 이름 gems 사용. psql 기본 접속은 시스템 DB postgres)
DATABASE_URL=postgresql://postgres:password@gems-db:5432/gems

# S3 (MinIO)
S3_ENDPOINT=https://storage-api.nanum.online
S3_ACCESS_KEY=gems_master
S3_SECRET_KEY=your_secret
S3_BUCKET=gems-receipts
# Presigned URL 유효 시간(초). 기본 600(10분). 60~3600 사이로 적용됨.
# PRESIGNED_URL_EXPIRES_SEC=600

# Naver OCR (CLOVA Document OCR) — STAY/TOUR 분기
# TOUR: 영수증 특화 모델. STAY: 일반 모델(인보이스/명세서)·템플릿 사용 권장.
# STAY/TOUR 미설정 시 아래 단일 설정이 TOUR·STAY 모두에 fallback.
# ※ STAY 템플릿 적용 전: TOUR와 동일한 Document Receipt 사용 시, 여기만 설정하고
#   STAY 전용 변수는 비워두면 됨. URL은 반드시 /document/receipt 로 끝나야 함.
#   상세: PROJECT/네이버_CLOVA_OCR_레퍼런스_및_인식률_검토.md §2-1
NAVER_OCR_INVOKE_URL=your_naver_url
NAVER_OCR_SECRET=your_naver_secret
# STAY 전용 (템플릿 적용 전에는 비워두면 NAVER_OCR_* 가 사용됨)
# NAVER_OCR_STAY_INVOKE_URL=
# NAVER_OCR_STAY_SECRET=
# TOUR 전용 (비워두면 NAVER_OCR_* 가 사용됨)
# NAVER_OCR_TOUR_INVOKE_URL=
# NAVER_OCR_TOUR_SECRET=
# 인식률 개선: 장축 최대 픽셀(기본 1960), JPEG 품질 1–100(기본 90). 생략 시 기본값 사용.
# OCR_MAX_DIMENSION=1960
# OCR_JPEG_QUALITY=90
# 컨피던스·보정: 90 이상이면 OCR 우선 신뢰. 70 미만 또는 핵심 필드(상점명·사업자·주소) 2개 미만이면 수동 검수(OCR_004).
# OCR_CONFIDENCE_THRESHOLD=90
# OCR_LOW_CONFIDENCE_REVIEW_THRESHOLD=70
# OCR_KEY_FIELDS_MIN_FILLED=2
# 인식률 향상(이미지 전처리): 저해상도 업스케일(1=활성), 업스케일 기준 장축(미만이면 1960까지 확대), 작은 이미지 PNG 전송(1=활성)
# OCR_UPSCALE_SMALL=0
# OCR_UPSCALE_MAX_SIDE=1200
# OCR_SEND_PNG_WHEN_SMALL=0

# Gemini (업종 자동 분류: 신규 상점 룰 불명확 시 API 호출)
# 적용 여부 확인: GET /api/health 응답의 gemini_configured 가 true 이면 키 설정됨. 실제 호출은 JudgmentRuleConfig.enable_gemini_classifier + 조건 만족 시에만 수행.
# GEMINI_API_KEY=your_gemini_key
# GEMINI_MODEL 미설정 시 기본값 gemini-2.5-flash (404 시 2.0-flash 등 폴백 자동 시도)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_SEC=12
# GEMINI_MAX_OUTPUT_TOKENS=32
GEMINI_API_KEY=

# FE 결과 수신 콜백 (분석 완료 시 POST, 미설정 시 미호출, 재시도 없음)
# 자동 분석 완료(purpose=auto) 시: 검증 전 오류율 감소를 위해 FIT일 때만 FE로 전송. UNFIT/ERROR 등은 스킵.
# 적용 위치: 1) 로컬/개발 → 프로젝트 루트 .env  2) 실서비스 → 배포 서버 환경변수(Coolify 등)
# 개발/테스트: FE 테스트 서버 URL
# 실서비스: FE 운영 서버 URL (개발→실서비스 전환 시 이 값만 해당 환경에서 변경)
# 적용 여부 확인: GET /api/health 응답의 ocr_callback_configured 가 true 이면 적용됨.
# OCR_RESULT_CALLBACK_URL=
# 개발 예시:
# OCR_RESULT_CALLBACK_URL=http://210.179.205.50/dg/coupon/api/ocr/result
# 실서비스 예시:
# OCR_RESULT_CALLBACK_URL=https://easy.gwd.go.kr/dg/coupon/api/ocr/result
OCR_RESULT_CALLBACK_URL=
# 콜백 타임아웃(초). 기본 15. 5~60 사이로 적용. 수신 서버가 느리면 20~30 권장.
# OCR_CALLBACK_TIMEOUT_SEC=15
# 콜백 연결/타임아웃 실패 시 재시도 횟수. 0=재시도 없음, 2=최대 3회 시도. 기본 2.
# OCR_CALLBACK_RETRIES=2

# 관리자 API (선택): 설정 시 /api/v1/admin/* 호출에 X-Admin-Key 헤더 필요
# ADMIN_API_KEY=your_admin_secret

# 크론 잡 전용: 설정 시 X-Cron-Secret으로 /api/v1/admin/jobs/cron/* 호출 가능. 장애 대응(VERIFYING 타임아웃 등) 스케줄러용.
# CRON_SECRET=your_cron_secret_32chars

# 담당자 로그인(JWT): 설정 시 POST /api/v1/auth/login 및 Bearer 인증 사용. 미설정 시 X-Admin-Key만 가능.
# JWT_SECRET=your_jwt_secret_32chars_or_longer
# JWT_EXPIRE_MINUTES=480
# 최초 슈퍼관리자 생성(스크립트): SUPER_ADMIN_EMAIL=admin@example.com SUPER_ADMIN_PASSWORD='Abc1!xyz' python PROJECT/scripts/create_super_admin.py

# 영수증 데이터 기준 시각(UTC): 이 시각 이후 인입된 데이터만 중복 판정에 사용. 이전 데이터와 섞이지 않게 함.
# 예: 2026-03-09 09:00 KST = 00:00 UTC → RECEIPT_DATA_CUTOFF_UTC=2026-03-09T00:00:00
# RECEIPT_DATA_CUTOFF_UTC=2026-03-09T00:00:00

# CORS: 쉼표 구분 오리진. 미설정 시 기본값( localhost:5173, localhost:8080, 169.254.240.5:8080 등) 사용
# CORS_ORIGINS=http://169.254.240.5:8080,http://169.254.240.5:8000
