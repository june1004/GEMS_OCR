# GEMS_OCR 환경 변수 (PROJECT/GEMS_PROJECT_GUIDE.md §4 참고)
# 사용법: 이 파일을 복사하여 .env 로 저장한 뒤 실제 값으로 채우세요.

# Database (반드시 사용자 DB 이름 gems 사용. psql 기본 접속은 시스템 DB postgres)
DATABASE_URL=postgresql://postgres:password@gems-db:5432/gems

# S3 (MinIO)
S3_ENDPOINT=https://storage-api.nanum.online
S3_ACCESS_KEY=gems_master
S3_SECRET_KEY=your_secret
S3_BUCKET=gems-receipts

# Naver OCR
NAVER_OCR_INVOKE_URL=your_naver_url
NAVER_OCR_SECRET=your_naver_secret

# Gemini
GEMINI_API_KEY=your_gemini_key

# FE 결과 수신 콜백 (분석 완료 시 POST, 미설정 시 미호출, 재시도 없음)
# 운영: https://easy.gwd.go.kr/dg/coupon/api/ocr/result
# 테스트: http://210.179.205.50/dg/coupon/api/ocr/result
OCR_RESULT_CALLBACK_URL=
